/* ================================================================
 * State Structure (frame-persistent caches)
 * ================================================================ */
typedef struct {
    int32_t conv_cache_e0[2 * 129];
    int32_t conv_cache_e1[24 * 65];
    int32_t conv_cache_e2[24 * 33];
    int32_t conv_cache_d0[24 * 33];
    int32_t conv_cache_d1[12 * 33];
    int32_t conv_cache_d2[12 * 2 * 65];
    int16_t tfa_cache_e0[24];
    int16_t tfa_cache_e1[48];
    int16_t tfa_cache_e2[48];
    int16_t tfa_cache_e3[64];
    int16_t tfa_cache_e4[32];
    int16_t tfa_cache_d0[64];
    int16_t tfa_cache_d1[48];
    int16_t tfa_cache_d2[48];
    int16_t tfa_cache_d3[24];
    int16_t tfa_cache_d4[2];
    int16_t inter_cache_0[33 * 16];
    int16_t inter_cache_1[33 * 16];
} ulunas_state_t;

static void ulunas_state_init(ulunas_state_t *st) {
    memset(st, 0, sizeof(ulunas_state_t));
}

/* ================================================================
 * FFT (Q15, 512-point Radix-2)
 * Matching MATLAB fft(x, N_fft) bit-for-bit
 * ================================================================ */
static void fft_q15_512(int32_t *real, int32_t *imag, int inverse) {
    for (int i = 0; i < 512; i++) {
        int j = fft_bit_rev[i];
        if (i < j) { int32_t t = real[i]; real[i] = real[j]; real[j] = t; t = imag[i]; imag[i] = imag[j]; imag[j] = t; }
    }
    for (int s = 0; s < 9; s++) {
        int m = 1 << s, m2 = m << 1;
        for (int k = 0; k < m; k++) {
            int tw = k * (512 / m2);
            int16_t wr = fft_tw_cos[tw];
            int16_t wi = inverse ? fft_tw_sin[tw] : (int16_t)(-fft_tw_sin[tw]);
            for (int j = k; j < 512; j += m2) {
                int j2 = j + m;
                int32_t tr = (int32_t)(((int64_t)real[j2] * wr - (int64_t)imag[j2] * wi) >> 15);
                int32_t ti = (int32_t)(((int64_t)imag[j2] * wr + (int64_t)real[j2] * wi) >> 15);
                real[j2] = real[j] - tr; imag[j2] = imag[j] - ti;
                real[j]  += tr;         imag[j]  += ti;
            }
        }
    }
}

/* ================================================================
 * LUT Functions
 * ================================================================ */
static uint16_t sigmoid_q20_to_q15(int32_t x_q20) {
    static const int32_t x_min = -8388608;
    if (x_q20 <= x_min) return 0;
    if (x_q20 >= 8388608) return 32768;
    int32_t offset = x_q20 - x_min;
    int32_t idx = offset >> 14;
    int32_t frac = offset & 0x3FFF;
    if (idx >= 1023) return sigmoid_lut_q15[1023];
    int32_t v0 = sigmoid_lut_q15[idx];
    int32_t v1 = sigmoid_lut_q15[idx + 1];
    return (uint16_t)(v0 + ((v1 - v0) * frac + 8192) / 16384);
}

static int16_t tanh_q20_to_q15(int32_t x_q20) {
    static const int32_t x_min = -4194304;
    if (x_q20 <= x_min) return -32768;
    if (x_q20 >= 4194304) return 32767;
    int32_t offset = x_q20 - x_min;
    int32_t idx = offset >> 13;
    int32_t frac = offset & 0x1FFF;
    if (idx >= 1023) return tanh_lut_q15[1023];
    int32_t v0 = tanh_lut_q15[idx];
    int32_t v1 = tanh_lut_q15[idx + 1];
    return (int16_t)(v0 + ((v1 - v0) * frac + 4096) / 8192);
}

static int32_t log10_q20(int32_t x_q20) {
    if (x_q20 <= 0) return -12582912;
    uint32_t v = (uint32_t)x_q20;
    int32_t log2_int = 0;
    uint32_t t = v;
    while (t >>= 1) log2_int++;
    int32_t exponent = log2_int - 19;
    int32_t shift = log2_int - 19;
    uint32_t mantissa;
    if (shift >= 0) mantissa = v >> shift;
    else mantissa = v << (-shift);
    int32_t lut_idx = (int32_t)(mantissa - 524288) >> 10;
    if (lut_idx < 0) lut_idx = 0;
    if (lut_idx >= 512) lut_idx = 511;
    int32_t log10_mantissa = log10_lut_q20[lut_idx];
    int32_t log10_exp = (int32_t)((int64_t)exponent * 315653LL);
    return log10_mantissa + log10_exp;
}

static uint32_t isqrt64(uint64_t x_q40) {
    if (x_q40 == 0) return 0;
    if (x_q40 == 1) return 1;
    uint64_t lo = 1, hi = x_q40;
    if (hi > 0xFFFFFFFFULL) hi = 0xFFFFFFFFULL;
    while (lo < hi) {
        uint64_t mid = (lo + hi + 1) >> 1;
        if (mid * mid <= x_q40) lo = mid;
        else hi = mid - 1;
    }
    return (uint32_t)lo;
}
/**
 * ulunas_nr_ops.c — UL-UNAS Core Fixed-Point Operators
 * =====================================================
 * Appended to ulunas_nr.c — all operators matching MATLAB modules 1:1.
 *
 * Every operator follows the MATLAB computation order exactly:
 *   1. Dequantize (if needed for nonlinear ops)
 *   2. Compute in float domain (for sqrt/log only, via LUT)
 *   3. Requantize
 *
 * For linear ops (conv, BN, FC): round each product, then accumulate in int64.
 */

/* ================================================================
 * STFT — Q15 fixed-point, matching MATLAB STFT_func.m
 * Mirror padding + Hann^2 window + Q15 FFT
 * Input:  noisy_audio (int16 Q15 samples)
 * Output: cmp_real[N_BINS], cmp_imag[N_BINS] in Q20 (Q15 << 5)
 * ================================================================ */
static void stft_fixed(const int16_t *x, int n_samples,
                       int32_t *cmp_real, int32_t *cmp_imag, int T) {
    int padded_len = PAD_LEN + n_samples + PAD_LEN;
    int16_t *xp = malloc(padded_len * sizeof(int16_t));
    /* Leading mirror: x[PAD_LEN] down to x[1] */
    for (int i = 0; i < PAD_LEN; i++) xp[i] = x[PAD_LEN - i];
    memcpy(xp + PAD_LEN, x, n_samples * sizeof(int16_t));
    for (int i = 0; i < PAD_LEN; i++) xp[PAD_LEN + n_samples + i] = x[n_samples - 2 - i];

    for (int t = 0; t < T; t++) {
        int start = t * WIN_INC;
        int32_t fft_in[512], imag[512];
        memset(imag, 0, sizeof(imag));
        /* Apply window: (sample * win + 16384) >> 15 -> Q15 */
        for (int i = 0; i < WIN_LEN; i++) {
            fft_in[i] = (int32_t)(((int64_t)xp[start + i] * hann2_win[i] + 16384) >> 15);
        }
        fft_q15_512(fft_in, imag, 0);
        /* Q15 -> Q20: << 5 */
        for (int b = 0; b < N_BINS; b++) {
            cmp_real[t * N_BINS + b] = fft_in[b] << 5;
            cmp_imag[t * N_BINS + b] = imag[b] << 5;
        }
    }
    free(xp);
}

/* ================================================================
 * log_gen — Log-Magnitude Compression
 * MATLAB: x_dq = x*2^(-20); mag = sqrt(real^2 + imag^2);
 *         y = Fix_point(log10(max(mag, 1e-12)), 's32f20')
 * Fixed:  mag_sq_q40 = real^2 + imag^2 (in Q40)
 *         mag_q20 = isqrt64(mag_sq_q40) (Q40 -> Q20)
 *         y = log10_q20(mag_q20)
 * ================================================================ */
static void log_gen_fixed(const int32_t *real, const int32_t *imag,
                          int W, int32_t *out) {
    for (int i = 0; i < W; i++) {
        int64_t r = real[i], im = imag[i];
        uint64_t mag_sq = (uint64_t)(r * r + im * im);  /* Q40 */
        uint32_t mag = isqrt64(mag_sq);                   /* Q20 */
        if (mag < 1) mag = 1;  /* clamp to 1e-12 equivalent */
        out[i] = log10_q20((int32_t)mag);
    }
}

/* ================================================================
 * BM_fixed — ERB Band Merging
 * MATLAB: y(1:65) = x(1:65); y(66:129) = round(x(66:257) * weight * 2^(-15))
 * ================================================================ */
static void bm_fixed(const int32_t *x, const uint16_t *weight,
                     int W_in, int W_out, int32_t *y) {
    /* Low freq pass-through: bins 0-64 */
    memcpy(y, x, 65 * sizeof(int32_t));
    /* High freq: matrix multiply (192 bins) * (192x64 weight) -> 64 bins */
    int n_high_in = W_in - 65;  /* 257 - 65 = 192 */
    int n_high_out = W_out - 65; /* 129 - 65 = 64 */
    for (int o = 0; o < n_high_out; o++) {
        int64_t acc = 0;
        for (int i = 0; i < n_high_in; i++) {
            acc += (int64_t)x[65 + i] * weight[o * n_high_in + i];
        }
        y[65 + o] = round_shr(acc, 15);  /* >> 15 */
    }
}

/* ================================================================
 * BS_fixed — ERB Band Splitting (inverse of BM)
 * MATLAB: y(1:65) = x(1:65); y(66:257) = round(x(66:129) * weight * 2^(-15))
 * ================================================================ */
static void bs_fixed(const uint16_t *x, const uint16_t *weight,
                     int W_in, int W_out, int16_t *y) {
    for (int i = 0; i < 65; i++) y[i] = (int16_t)x[i];
    int n_high_in = W_in - 65;   /* 129 - 65 = 64 */
    int n_high_out = W_out - 65; /* 257 - 65 = 192 */
    for (int o = 0; o < n_high_out; o++) {
        int64_t acc = 0;
        for (int i = 0; i < n_high_in; i++) {
            acc += (int64_t)x[65 + i] * weight[i * n_high_out + o];
        }
        y[65 + o] = clamp_i16(round_shr(acc, 15));
    }
}

/* ================================================================
 * MASK_fixed — CRM Mask Application
 * MATLAB: y_real = round(x_real .* mask * 2^(-15))
 *         y_imag = round(x_imag .* mask * 2^(-15))
 *         y = cat(1, y_real, y_imag) * 2^(-20) (stored as Q20 int)
 * ================================================================ */
static void mask_fixed(const int16_t *mask, const int32_t *x_real,
                       const int32_t *x_imag, int W, int32_t *y) {
    for (int i = 0; i < W; i++) {
        int64_t prod_r = (int64_t)x_real[i] * mask[i];
        int64_t prod_i = (int64_t)x_imag[i] * mask[i];
        y[i]       = round_shr(prod_r, 15);  /* Q20 -> Q5 -> back to Q20? No: round(x_real*mask*2^(-15)) */
        y[W + i]   = round_shr(prod_i, 15);
    }
}

/* ================================================================
 * bn_func — Batch Normalization
 * MATLAB:
 *   x_norm = round((x - mean) .* running_var * 2^Qr1)
 *   y = round(x_norm .* weight * 2^Qr2) + bias
 * Each channel processed independently.
 * weight: int16_t or uint16_t, running_var: uint16_t
 * ================================================================ */
static void bn_func_sw(const int32_t *x, const int16_t *weight,
                        const int32_t *bias, const int32_t *running_mean,
                        const uint16_t *running_var, int Qr1, int Qr2,
                        int C, int N, int32_t *y) {
    if (!x || !weight || !bias || !running_mean || !running_var || !y) {
        return;
    }
    int shift1 = -Qr1, shift2 = -Qr2;
    int64_t r1 = ((int64_t)1 << (shift1 - 1));
    int64_t r2 = ((int64_t)1 << (shift2 - 1));
    int per_ch = N / C;
    for (int c = 0; c < C; c++) {
        int32_t mean = running_mean[c];
        uint16_t var = running_var[c];
        int16_t w = weight[c];
        int32_t b = bias[c];
        for (int n = 0; n < per_ch; n++) {
            int idx = c * per_ch + n;
            int64_t diff = (int64_t)(x[idx] - mean);
            int64_t norm_val;
            if (diff >= 0) norm_val = (diff * var + r1) >> shift1;
            else           norm_val = (diff * var - r1) >> shift1;
            int64_t scaled;
            if (norm_val >= 0) scaled = (norm_val * w + r2) >> shift2;
            else               scaled = (norm_val * w - r2) >> shift2;
            y[idx] = sat_i32(scaled + b);
        }
    }
}

static void bn_func_uw(const int32_t *x, const uint16_t *weight,
                        const int32_t *bias, const int32_t *running_mean,
                        const uint16_t *running_var, int Qr1, int Qr2,
                        int C, int N, int32_t *y) {
    int shift1 = -Qr1, shift2 = -Qr2;
    int64_t r1 = ((int64_t)1 << (shift1 - 1));
    int64_t r2 = ((int64_t)1 << (shift2 - 1));
    int per_ch = N / C;
    for (int c = 0; c < C; c++) {
        int32_t mean = running_mean[c];
        uint16_t var = running_var[c];
        uint16_t w = weight[c];
        int32_t b = bias[c];
        for (int n = 0; n < per_ch; n++) {
            int idx = c * per_ch + n;
            int64_t diff = (int64_t)(x[idx] - mean);
            int64_t norm_val;
            if (diff >= 0) norm_val = (diff * var + r1) >> shift1;
            else           norm_val = (diff * var - r1) >> shift1;
            int64_t scaled;
            if (norm_val >= 0) scaled = (norm_val * w + r2) >> shift2;
            else               scaled = (norm_val * w - r2) >> shift2;
            y[idx] = sat_i32(scaled + b);
        }
    }
}

/* ================================================================
 * affineprelu_func — Affine PReLU
 * MATLAB: x_copy = x; idx = x < 0; x(idx) = round(x(idx).*slope(row)*2^Qr1)
 *         y = round(x_copy.*weight*2^Qr2) + bias + x
 * ================================================================ */
static void affineprelu_func(const int32_t *x, const int16_t *weight,
                              const int32_t *bias, const int16_t *slope,
                              int Qr1, int Qr2, int C, int W, int32_t *y) {
    int shift1 = -Qr1, shift2 = -Qr2;
    int64_t r1 = ((int64_t)1 << (shift1 - 1));
    int64_t r2 = ((int64_t)1 << (shift2 - 1));

    for (int c = 0; c < C; c++) {
        int16_t w = weight[c];
        int32_t b = bias[c];
        int16_t s = slope[c];
        for (int w_idx = 0; w_idx < W; w_idx++) {
            int idx = c * W + w_idx;
            int32_t x_val = x[idx];
            int32_t x_copy = x_val;  /* save original */

            /* Negative part: multiply by slope */
            int32_t x_neg = 0;
            if (x_val < 0) {
                int64_t prod = (int64_t)x_val * s;
                if (prod >= 0) x_neg = (int32_t)((prod + r1) >> shift1);
                else           x_neg = (int32_t)((prod - r1) >> shift1);
            }

            /* Affine part: round(x_copy * weight * 2^Qr2) */
            int64_t prod2 = (int64_t)x_copy * w;
            int32_t affine;
            if (prod2 >= 0) affine = (int32_t)((prod2 + r2) >> shift2);
            else            affine = (int32_t)((prod2 - r2) >> shift2);

            y[idx] = sat_i32((int64_t)affine + b + x_neg);
        }
    }
}

/* ================================================================
 * ln_func — Layer Normalization
 * MATLAB:
 *   x_dq = x * 2^(-20); mean_val = mean(x_dq); var_val = 1/sqrt(var(x_dq)+1e-8)
 *   running_mean = Fix_point(mean_val, 's32f20')
 *   running_var = Fix_point(var_val, 'u16f11')
 *   x_norm = round((x - mean) * var * 2^(-11))
 *   y = round(x_norm .* weight * 2^Qr) + bias
 *
 * NOTE: LN uses float math for mean/var as MATLAB does x*2^(-20) dequant.
 *       This is the ONLY place float is used — matching MATLAB golden exactly.
 * ================================================================ */
static void ln_func(const int32_t *x, const int16_t *weight,
                    const int32_t *bias, int Qr, int C, int N, int32_t *y) {
    /* Compute float mean and 1/sqrt(var) */
    double sum = 0.0, sum_sq = 0.0;
    for (int i = 0; i < N; i++) {
        double v = (double)x[i] / Q20_SCALE;
        sum += v;
        sum_sq += v * v;
    }
    double mean_f = sum / N;
    double var_f = (sum_sq / N) - (mean_f * mean_f);
    double inv_std = 1.0 / sqrt(var_f + 1e-8);

    int32_t mean_q20 = (int32_t)round(mean_f * Q20_SCALE);
    uint16_t var_q11 = (uint16_t)round(inv_std * Q11_SCALE);
    if (var_q11 > 65535) var_q11 = 65535;

    int shift_norm = 11;
    int64_t r_norm = (1 << 10);  /* 2^(shift_norm-1) */
    int shift_w = -Qr;
    int64_t r_w = ((int64_t)1 << (shift_w - 1));

    int per_ch = N / C;
    for (int c = 0; c < C; c++) {
        int16_t w = weight[c];
        int32_t b = bias[c];
        for (int n = 0; n < per_ch; n++) {
            int idx = c * per_ch + n;
            int64_t diff = (int64_t)(x[idx] - mean_q20);
            int64_t norm_val;
            if (diff >= 0) norm_val = (diff * var_q11 + r_norm) >> shift_norm;
            else           norm_val = (diff * var_q11 - r_norm) >> shift_norm;
            int64_t scaled;
            if (norm_val >= 0) scaled = (norm_val * w + r_w) >> shift_w;
            else               scaled = (norm_val * w - r_w) >> shift_w;
            y[idx] = sat_i32(scaled + b);
        }
    }
}

/* ================================================================
 * gru_module — Single-direction GRU
 * MATLAB GRU_module.m (exact 1:1):
 *   r_t = round(x_t*ih_r*2^Qr1) + round(h*hh_r*2^Qr2) + ih_r_b + hh_r_b
 *   r_t = Fix_point(sigmoid(r_t * 2^(-20)), 'u16f15')
 *   z_t = round(x_t*ih_z*2^Qr1) + round(h*hh_z*2^Qr2) + ih_z_b + hh_z_b
 *   z_t = Fix_point(sigmoid(z_t * 2^(-20)), 'u16f15')
 *   h_t = round(h*hh_n*2^Qr2) + hh_n_b
 *   n_t = round(x_t*ih_n*2^Qr1) + round(r_t .* h_t * 2^(-15)) + ih_n_b
 *   n_t = Fix_point(tanh(n_t * 2^(-20)), 's16f15')
 *   h_cache = round((32768-z_t).*n_t*2^(-15)) + round(z_t.*h*2^(-15))
 * Input:  x_t[in_dim] in Q20, h_cache[nHidden] in Q15
 * Output: y[nHidden] = h_cache in Q15
 * ================================================================ */
static void gru_module(const int32_t *x_t, int nHidden, int in_dim,
                        int16_t *h_cache,
                        const int16_t *ih_weight, const int32_t *ih_bias,
                        const int16_t *hh_weight, const int32_t *hh_bias,
                        int Qr1, int Qr2, int16_t *y) {
    int shift1 = -Qr1, shift2 = -Qr2;
    int64_t r1 = ((int64_t)1 << (shift1 - 1));
    int64_t r2 = ((int64_t)1 << (shift2 - 1));

    /* Split ih_weight: [in_dim, 3*nHidden] col-major -> r, z, n */
    int ih_stride = in_dim;  /* col-major: each column is one output neuron */
    const int16_t *ih_r = ih_weight;
    const int16_t *ih_z = ih_weight + nHidden * ih_stride;
    const int16_t *ih_n = ih_weight + 2 * nHidden * ih_stride;

    int hh_stride = nHidden;
    const int16_t *hh_r = hh_weight;
    const int16_t *hh_z = hh_weight + nHidden * hh_stride;
    const int16_t *hh_n = hh_weight + 2 * nHidden * hh_stride;

int32_t r_q20[64], z_q20[64], n_q20[64];
int32_t h_t_q20[64];

    /* --- Reset gate R --- */
    for (int j = 0; j < nHidden; j++) {
        int64_t acc = 0;
        for (int i = 0; i < in_dim; i++)
            acc += (int64_t)x_t[i] * ih_r[j * ih_stride + i];
        int32_t ih_part = round_shr(acc, shift1);
        acc = 0;
        for (int i = 0; i < nHidden; i++)
            acc += (int64_t)h_cache[i] * hh_r[j * hh_stride + i];
        int32_t hh_part = round_shr(acc, shift2);
        r_q20[j] = sat_i32((int64_t)ih_part + hh_part + ih_bias[j] + hh_bias[j]);
    }
uint16_t r_q15[64];
    for (int j = 0; j < nHidden; j++) r_q15[j] = sigmoid_q20_to_q15(r_q20[j]);

    /* --- Update gate Z --- */
    for (int j = 0; j < nHidden; j++) {
        int64_t acc = 0;
        for (int i = 0; i < in_dim; i++)
            acc += (int64_t)x_t[i] * ih_z[j * ih_stride + i];
        int32_t ih_part = round_shr(acc, shift1);
        acc = 0;
        for (int i = 0; i < nHidden; i++)
            acc += (int64_t)h_cache[i] * hh_z[j * hh_stride + i];
        int32_t hh_part = round_shr(acc, shift2);
        z_q20[j] = sat_i32((int64_t)ih_part + hh_part + ih_bias[j + nHidden] + hh_bias[j + nHidden]);
    }
uint16_t z_q15[64];
    for (int j = 0; j < nHidden; j++) z_q15[j] = sigmoid_q20_to_q15(z_q20[j]);

    /* --- Candidate hidden state --- */
    for (int j = 0; j < nHidden; j++) {
        int64_t acc = 0;
        for (int i = 0; i < nHidden; i++)
            acc += (int64_t)h_cache[i] * hh_n[j * hh_stride + i];
        h_t_q20[j] = sat_i32(round_shr(acc, shift2) + hh_bias[j + 2 * nHidden]);
    }
    for (int j = 0; j < nHidden; j++) {
        int64_t acc = 0;
        for (int i = 0; i < in_dim; i++)
            acc += (int64_t)x_t[i] * ih_n[j * ih_stride + i];
        int32_t ih_part = round_shr(acc, shift1);
        int64_t gate_part = ((int64_t)r_q15[j] * h_t_q20[j] + 16384) >> 15;
        n_q20[j] = sat_i32((int64_t)ih_part + gate_part + ih_bias[j + 2 * nHidden]);
    }
int16_t n_q15[64];
    for (int j = 0; j < nHidden; j++) n_q15[j] = tanh_q20_to_q15(n_q20[j]);

    /* --- Update hidden state --- */
    for (int j = 0; j < nHidden; j++) {
        int64_t term1 = ((int64_t)(32768 - z_q15[j]) * n_q15[j] + 16384) >> 15;
        int64_t term2 = ((int64_t)z_q15[j] * h_cache[j] + 16384) >> 15;
        h_cache[j] = clamp_i16((int32_t)(term1 + term2));
        y[j] = h_cache[j];
    }
}

/* ================================================================
 * bigru_module — Bidirectional GRU
 * MATLAB BiGRU_module.m: forward + reversed, concat
 * Input:  x[T][in_dim] in Q20
 * Output: y[T][2*nHidden] in Q15
 * ================================================================ */
static void bigru_module(const int32_t *x, int T, int nHidden, int in_dim,
                          const int16_t *ih_weight, const int32_t *ih_bias,
                          const int16_t *hh_weight, const int32_t *hh_bias,
                          const int16_t *re_ih_weight, const int32_t *re_ih_bias,
                          const int16_t *re_hh_weight, const int32_t *re_hh_bias,
                          int Qr1, int Qr2, int16_t *y) {
int16_t h_cache[64], h_cache_re[64];
    memset(h_cache, 0, sizeof(h_cache));
    memset(h_cache_re, 0, sizeof(h_cache_re));

    /* Forward direction */
    for (int t = 0; t < T; t++) {
        gru_module(x + t * in_dim, nHidden, in_dim, h_cache,
                   ih_weight, ih_bias, hh_weight, hh_bias, Qr1, Qr2,
                   y + t * (2 * nHidden));
    }
    /* Reverse direction */
    int16_t y_rev[33 * 16];  /* T up to 33, 2*nHidden up to 16 */
    for (int t = 0; t < T; t++) {
        int rev_t = T - 1 - t;
        /* Note: MATLAB processes reversed input, but stores in reversed position */
        gru_module(x + rev_t * in_dim, nHidden, in_dim, h_cache_re,
                   re_ih_weight, re_ih_bias, re_hh_weight, re_hh_bias, Qr1, Qr2,
                   y_rev + rev_t * nHidden);
    }
    /* Concatenate: y = [forward, reverse] */
    for (int t = 0; t < T; t++) {
        memcpy(y + t * (2 * nHidden) + nHidden, y_rev + t * nHidden, nHidden * sizeof(int16_t));
    }
}

/* ================================================================
 * ctfa_ta_module — Channel-wise Time Attention
 * MATLAB: x^2 -> mean over W -> GRU -> FC -> sigmoid -> u16f15
 * Input:  x[C][W] in Q20
 * Output: y[C] in u16f15
 * ================================================================ */
static void ctfa_ta_module(const int32_t *x, int C, int W, int nHidden,
                            int16_t *h_cache,
                            const int16_t *ih_weight, const int32_t *ih_bias,
                            const int16_t *hh_weight, const int32_t *hh_bias,
                            const int16_t *fc_weight, const int32_t *fc_bias,
                            int Qr1, int Qr2, int fc_Qr, uint16_t *y) {
    /* Square + mean over W */
    int32_t x_agg[64];  /* max C=64 */
    for (int c = 0; c < C; c++) {
        int64_t sum_sq = 0;
        for (int w = 0; w < W; w++) {
            int32_t val = x[c * W + w];
            sum_sq += (int64_t)val * val;
        }
        /* Dequant square to Q40, then average and requantize to Q20 */
        /* MATLAB: x_dq = x*2^(-20); x_sq = x_dq^2; x_agg = mean(x_sq,2)'
         *         x_t = Fix_point(x_agg, 'u32f20')
         * Fixed: sum_sq is Q40, /W gives average in Q40, >>20 gives Q20
         */
        int32_t avg_q20 = (int32_t)((sum_sq / W + (1 << 19)) >> 20);
        x_agg[c] = avg_q20;
    }

    /* GRU: x_t[1][C] in Q20, h_cache[nHidden] in Q15 */
    int16_t x_gru_out[64];
    gru_module(x_agg, nHidden, C, h_cache,
               ih_weight, ih_bias, hh_weight, hh_bias, Qr1, Qr2,
               x_gru_out);

    /* FC: round(x_gru * fc_weight * 2^fc_Qr) + fc_bias */
    int shift_fc = -fc_Qr;
    int64_t r_fc = ((int64_t)1 << (shift_fc - 1));
    for (int o = 0; o < C; o++) {
        int64_t acc = 0;
        for (int i = 0; i < nHidden; i++) {
            acc += (int64_t)x_gru_out[i] * fc_weight[o * nHidden + i];
        }
        int32_t fc_out;
        if (acc >= 0) fc_out = (int32_t)((acc + r_fc) >> shift_fc);
        else          fc_out = (int32_t)((acc - r_fc) >> shift_fc);
        y[o] = sigmoid_q20_to_q15(sat_i32((int64_t)fc_out + fc_bias[o]));
    }
}

/* ================================================================
 * ctfa_fa_module — Frequency Attention
 * MATLAB: x^2 -> mean over C -> pad -> reshape -> BiGRU -> FC -> reshape -> sigmoid
 * Input:  x[C][W] in Q20
 * Output: y[W] in u16f15
 * ================================================================ */
static void ctfa_fa_module(const int32_t *x, int C, int W, int nHidden,
                            int group, int seg, int pad_len,
                            const int16_t *ih_w, const int32_t *ih_b,
                            const int16_t *hh_w, const int32_t *hh_b,
                            const int16_t *re_ih_w, const int32_t *re_ih_b,
                            const int16_t *re_hh_w, const int32_t *re_hh_b,
                            const int16_t *fc_w, const int32_t *fc_b,
                            int Qr1, int Qr2, int fc_Qr, uint16_t *y) {
    /* Square + mean over C */
    int32_t x_agg[256];
    for (int w = 0; w < W; w++) {
        int64_t sum_sq = 0;
        for (int c = 0; c < C; c++) {
            int32_t val = x[c * W + w];
            sum_sq += (int64_t)val * val;
        }
        int32_t avg_q20 = (int32_t)((sum_sq / C + (1 << 19)) >> 20);
        x_agg[w] = avg_q20;
    }

    /* Pad: [x_agg, zeros(1, pad_len)] */
    int padded_len = W + pad_len;
    int32_t x_padded[256];
    memcpy(x_padded, x_agg, W * sizeof(int32_t));
    memset(x_padded + W, 0, pad_len * sizeof(int32_t));

    /* Reshape: [group, seg] -> input to BiGRU is [seg][group] */
    /* MATLAB: x_t = reshape(x_pad, [group, seg])'  */
    int32_t x_reshape[68 * 8];  /* [seg][group] */
    for (int s = 0; s < seg; s++)
        for (int g = 0; g < group; g++)
            x_reshape[s * group + g] = x_padded[g * seg + s];

    /* BiGRU */
    int16_t x_gru_out[68 * 16];  /* [seg][2*nHidden] */
    bigru_module(x_reshape, seg, nHidden, group,
                 ih_w, ih_b, hh_w, hh_b,
                 re_ih_w, re_ih_b, re_hh_w, re_hh_b,
                 Qr1, Qr2, x_gru_out);

    /* FC: round(x_gru * fc_weight * 2^fc_Qr) + fc_bias */
    int bigru_out = 2 * nHidden;
    int shift_fc = -fc_Qr;
    int64_t r_fc = ((int64_t)1 << (shift_fc - 1));
    int32_t fc_out_all[256];  /* group * seg */
    for (int s = 0; s < seg; s++) {
        for (int g = 0; g < group; g++) {
            int64_t acc = 0;
            for (int i = 0; i < bigru_out; i++) {
                acc += (int64_t)x_gru_out[s * bigru_out + i] *
                       fc_w[g * seg * bigru_out + s * bigru_out + i];
            }
            if (acc >= 0) fc_out_all[g * seg + s] = (int32_t)((acc + r_fc) >> shift_fc);
            else          fc_out_all[g * seg + s] = (int32_t)((acc - r_fc) >> shift_fc);
            fc_out_all[g * seg + s] = sat_i32((int64_t)fc_out_all[g * seg + s] + fc_b[g * seg + s]);
        }
    }

    /* Reshape to 1D and sigmoid, take first W elements */
    for (int w = 0; w < W; w++) {
        y[w] = sigmoid_q20_to_q15(fc_out_all[w]);
    }
}

/* ================================================================
 * Shuffle operators
 * ================================================================ */
static void shuffle_interleave(const int32_t *src, int C, int W, int32_t *dst) {
    int half = C / 2;
    for (int w = 0; w < W; w++) {
        for (int c = 0; c < half; c++) {
            dst[(2 * c) * W + w]     = src[c * W + w];
            dst[(2 * c + 1) * W + w] = src[(half + c) * W + w];
        }
    }
}
static void shuffle_deinterleave(const int32_t *src, int C, int W, int32_t *dst) {
    int half = C / 2;
    for (int w = 0; w < W; w++) {
        for (int c = 0; c < half; c++) {
            dst[c * W + w]           = src[(2 * c) * W + w];
            dst[(half + c) * W + w]  = src[(2 * c + 1) * W + w];
        }
    }
}

/* ================================================================
 * pconv2d_func — Point-wise (1x1) Convolution
 * Simplified: each output = sum(input_ch * weight) + bias
 * weight[Cout][Cin] col-major
 * ================================================================ */
static void pconv2d_func(const int32_t *x, int Cin, int Cout, int Wout,
                          const int16_t *weight, const int32_t *bias,
                          int Qr, int weight_stride, int32_t *y) {
    int shift = -Qr;
    int64_t rnd = ((int64_t)1 << (shift - 1));
    for (int co = 0; co < Cout; co++) {
        for (int w = 0; w < Wout; w++) {
            int64_t acc = 0;
            for (int ci = 0; ci < Cin; ci++) {
                int64_t prod = (int64_t)x[ci * Wout + w] * weight[co + weight_stride * ci];
                if (prod >= 0) acc += (prod + rnd) >> shift;
                else           acc += (prod - rnd) >> shift;
            }
            y[co * Wout + w] = sat_i32(acc + bias[co]);
        }
    }
}

/* ================================================================
 * gconv2d_func — Grouped Temporal Convolution (with cache)
 * Input = [cache; x] along time dimension
 * Each output channel independent (Cin=1 per group)
 * ================================================================ */
static void gconv2d_func(const int32_t *x, int Cout, int Wout,
                          int Kh, int Kw, int stride_w,
                          const int16_t *weight, const int32_t *bias, int Qr,
                          int Wx, int32_t *cache, int32_t *dstcache, int32_t *y) {
    int shift = -Qr;
    int64_t rnd = ((int64_t)1 << (shift - 1));
    int cache_h = Kh - 1;

    for (int co = 0; co < Cout; co++) {
        for (int w = 0; w < Wout; w++) {
            int64_t acc = 0;
            for (int kh = 0; kh < Kh; kh++) {
                for (int kw = 0; kw < Kw; kw++) {
                    int w_src = w * stride_w + kw - ((Kw - 1) / 2);
                    int32_t x_val;
                    if (w_src < 0 || w_src >= Wx) x_val = 0;
                    else if (kh < cache_h)        x_val = cache[(kh * Cout + co) * Wx + w_src];
                    else                          x_val = x[co * Wx + w_src];
                    int16_t w_val = weight[co + Cout * (kh + Kh * kw)];
                    int64_t prod = (int64_t)x_val * w_val;
                    if (prod >= 0) acc += (prod + rnd) >> shift;
                    else           acc += (prod - rnd) >> shift;
                }
            }
            y[co * Wout + w] = sat_i32(acc + bias[co]);
        }
    }
    /* Update cache: shift old cache up, append x */
    if (dstcache) {
        memcpy(dstcache, cache + Cout * Wx, (cache_h - 1) * Cout * Wx * sizeof(int32_t));
        memcpy(dstcache + (cache_h - 1) * Cout * Wx, x, Cout * Wx * sizeof(int32_t));
    }
}

/* ================================================================
 * conv2d_func — Standard 2D Convolution
 * x[Cin][H][W] with padding
 * weight[Cout][Cin][Kh][Kw] col-major
 * ================================================================ */
static void conv2d_func(const int32_t *x, int Cin, int Cout, int Wout,
                         int Kh, int Kw, int stride_w, int Hx,
                         const int16_t *weight, const int32_t *bias, int Qr,
                         int32_t *y) {
    int shift = -Qr;
    int64_t rnd = ((int64_t)1 << (shift - 1));
    int pad_w = (Kw - 1) / 2;
    int Wx = (Wout - 1) * stride_w + Kw - 2 * pad_w;

    for (int co = 0; co < Cout; co++) {
        for (int w = 0; w < Wout; w++) {
            int64_t acc = 0;
            for (int ci = 0; ci < Cin; ci++) {
                for (int kh = 0; kh < Kh; kh++) {
                    for (int kw = 0; kw < Kw; kw++) {
                        int w_src = w * stride_w + kw - pad_w;
                        int32_t x_val;
                        if (w_src < 0 || w_src >= Wx) x_val = 0;
                        else x_val = x[(ci * Hx + kh) * Wx + w_src];
                        int16_t w_val = weight[co + Cout * (ci + Cin * (kh + Kh * kw))];
                        int64_t prod = (int64_t)x_val * w_val;
                        if (prod >= 0) acc += (prod + rnd) >> shift;
                        else           acc += (prod - rnd) >> shift;
                    }
                }
            }
            y[co * Wout + w] = sat_i32(acc + bias[co]);
        }
    }
}

/* ================================================================
 * non_gconv2d_func — Grouped Non-Temporal Conv (no cache, freq-dim kernel)
 * 1x5 kernel along frequency, each output channel independent
 * ================================================================ */
static void non_gconv2d_func(const int32_t *x, int Cout, int Wout,
                              int Kw, int stride_w,
                              const int16_t *weight, const int32_t *bias, int Qr,
                              int32_t *y) {
    int shift = -Qr;
    int64_t rnd = ((int64_t)1 << (shift - 1));
    int Kh = 1;

    for (int co = 0; co < Cout; co++) {
        for (int w = 0; w < Wout; w++) {
            int64_t acc = 0;
            for (int kw = 0; kw < Kw; kw++) {
                int w_src = w * stride_w + kw - ((Kw - 1) / 2);
                int32_t x_val;
                if (w_src < 0 || w_src >= Wout) x_val = 0;
                else x_val = x[co * Wout + w_src];
                int16_t w_val = weight[co + Cout * (0 + 1 * kw)]; /* [Cout][1][1][Kw] */
                int64_t prod = (int64_t)x_val * w_val;
                if (prod >= 0) acc += (prod + rnd) >> shift;
                else           acc += (prod - rnd) >> shift;
            }
            y[co * Wout + w] = sat_i32(acc + bias[co]);
        }
    }
}

/* ================================================================
 * cTFA Fusion
 * MATLAB: y_t = round(x .* (ta') * 2^(-15))
 *         y   = round(y_t .* fa * 2^(-15))
 * ================================================================ */
static void ctfa_fusion(const int32_t *x, const uint16_t *ta,
                         const uint16_t *fa, int C, int W, int32_t *y) {
    for (int c = 0; c < C; c++) {
        for (int w = 0; w < W; w++) {
            int64_t prod1 = (int64_t)x[c * W + w] * ta[c];
            int32_t y_t = round_shr(prod1, 15);
            int64_t prod2 = (int64_t)y_t * fa[w];
            y[c * W + w] = round_shr(prod2, 15);
        }
    }
}

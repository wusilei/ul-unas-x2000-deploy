/**
 * ulunas_nr.c — UL-UNAS Pure C Fixed-Point Noise Reduction
 * ==========================================================
 * Complete MATLAB→C fixed-point conversion following Main_infer.m pipeline.
 *
 * Pipeline: STFT → log_gen → BM → Encoder(5 layers) → GDPRNN(×2) →
 *           Decoder(5 layers) → Sigmoid → BS → MASK → ISTFT
 *
 * Q-format (matching MATLAB Fix_point.m and stft_fixed_point_guide.md):
 *   s32f20: main activations (Q_ACT=20)
 *   s16f15: GRU hidden state, tanh output (Q_GRU_H=15)
 *   u16f15: sigmoid output, ERB weights (Q_SIG=15)
 *   u16f11: LN 1/sqrt(var)
 *
 * Verification: noisy_fileid_1.wav Frame 0, per-stage SNR vs MATLAB golden
 *
 * Target: Ingenic X2000 (MIPS32R2, no FPU) + PC gcc verification
 */

#include <stdio.h>
